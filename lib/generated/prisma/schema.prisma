generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Products {
  product_id      String            @id @db.VarChar(50)
  title           String            @db.VarChar(255)
  main_category   String?           @db.VarChar(100)
  average_rating  Float?
  rating_number   Int?
  price           Float?
  store           String?           @db.VarChar(100)
  details         Json?
  images          Json?
  videos          Json?
  features        Json?
  descriptions    Json?
  categories      Json?
  bought_together Json?
  Recommendations Recommendations[]
  Reviews         Reviews[]
}

model Recommendations {
  recommendation_id Int      @id @default(autoincrement())
  user_id           String   @db.VarChar(50)
  product_id        String   @db.VarChar(50)
  score             Float
  timestamp         BigInt
  Products          Products @relation(fields: [product_id], references: [product_id], onDelete: NoAction, onUpdate: NoAction)
  Users             Users    @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, product_id, timestamp])
  @@index([user_id], map: "idx_recommendations_user_id")
}

model Reviews {
  review_id         Int      @id @default(autoincrement())
  product_id        String   @db.VarChar(50)
  user_id           String   @db.VarChar(50)
  rating            Float
  title             String?  @db.VarChar(255)
  text              String
  timestamp         BigInt
  helpful_vote      Int?     @default(0)
  verified_purchase Boolean? @default(false)
  asin              String?  @db.VarChar(50)
  images            Json?
  Products          Products @relation(fields: [product_id], references: [product_id], onDelete: NoAction, onUpdate: NoAction)
  Users             Users    @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([product_id, user_id, timestamp])
  @@index([product_id], map: "idx_reviews_product_id")
  @@index([user_id], map: "idx_reviews_user_id")
}

model Users {
  user_id         String            @id @db.VarChar(50)
  username        String            @db.VarChar(100)
  Recommendations Recommendations[]
  Reviews         Reviews[]
}
